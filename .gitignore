# === FICHIER .GITIGNORE ===
# Ce fichier indique à Git quels fichiers ou dossiers il ne doit PAS suivre (ignorer).
# Cela permet d'éviter d'envoyer des fichiers inutiles ou sensibles sur le dépôt.

# Dépendances (les bibliothèques installées via npm)
# On ne les envoie jamais car elles sont reconstruites avec 'npm install'.
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Résultats de tests
/coverage

# Dossiers de travail de Next.js (générés automatiquement lors du développement ou du build)
/.next/
/out/

# Dossier de production (le résultat final du site prêt à être déployé)
/build

# Fichiers divers (système d'exploitation ou clés de sécurité)
.DS_Store
*.pem

# Fichiers de log (journaux d'erreurs générés par npm ou yarn)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Fichiers de configuration locale (Variables d'environnement)
# TRÈS IMPORTANT : On ignore .env.local car il contient vos clés secrètes (Firebase, etc.)
.env*.local

# Dossiers spécifiques à l'hébergeur Vercel
.vercel

# Informations de build TypeScript
*.tsbuildinfo
next-env.d.ts
